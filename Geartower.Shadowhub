local TrollTab = Window:Tab({
    Title = "Troll",
    Icon = "bomb"
})

local autoBomb = false
local autoButtonTroll = false
local autoTouchDisappearParts = false

TrollTab:Toggle({
    Title = "Auto Bomb",
    Description = "Auto get bomb, equip and teleport 2 studs behind players",
    Default = false,
    Callback = function(state)
        autoBomb = state
    end
})

TrollTab:Toggle({
    Title = "Auto Troll Buttons",
    Description = "Automatically touch ALL troll buttons at once",
    Default = false,
    Callback = function(state)
        autoButtonTroll = state
    end
})

TrollTab:Toggle({
    Title = "Auto Touch DisappearParts",
