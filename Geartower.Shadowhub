loadstring(game:HttpGet("https://raw.githubusercontent.com/ShadowDRAGONZ/Menu-load/refs/heads/main/GearSlapTower.UpdateLog"))()
-- 1. Load Wind UI Library
local WindUI = loadstring(game:HttpGet("https://github.com/Footagesus/WindUI/releases/latest/download/main.lua"))()

-- 2. Create Menu (Window)
local Window = WindUI:CreateWindow({
    Title = "Shadow Hub", 
    Icon = "crown",       
    Author = "Menu",
    Folder = "AutoFarm",
    Transparent = true
})

-- ============================================================
-- STARTUP ACTIONS (Execution Count, Delete BubbleChat & Notification)
-- ============================================================
task.spawn(function()
    pcall(function()
        local rep = game:GetService("ReplicatedStorage")
        local player = game:GetService("Players").LocalPlayer
        
        -- System for counting executions
        local fileName = "ShadowHub_ExecutionCount.txt"
        local runCount = 1
        
        pcall(function()
            if isfile and isfile(fileName) then
                local content = readfile(fileName)
                local count = tonumber(content)
                if count then
                    runCount = count + 1
                end
            end
            if writefile then
                writefile(fileName, tostring(runCount))
            end
        end)
        
        -- Delete ForceBubbleChat
        local forceBubbleChat = rep:FindFirstChild("HDAdminHDClient") 
            and rep.HDAdminHDClient:FindFirstChild("Signals") 
            and rep.HDAdminHDClient.Signals:FindFirstChild("ForceBubbleChat")
        
        if forceBubbleChat then
            forceBubbleChat:Destroy()
        end
        
        -- Send welcome notification (English)
        local notifyEvent = rep:FindFirstChild("HDAdminHDClient")
            and rep.HDAdminHDClient:FindFirstChild("Signals")
            and rep.HDAdminHDClient.Signals:FindFirstChild("Error")
            
        if notifyEvent then
            local playerName = player.Name
            local welcomeMessage = string.format("👋 Hello %s, thank you for using Shadow Hub. This is the %d time you have used Shadow Hub! 👑✨", playerName, runCount)
            
            firesignal(notifyEvent.OnClientEvent, {
                "System",
                welcomeMessage
            })
        end
    end)
end)

-- ============================================================
-- [TAB 1: AUTO]
-- ============================================================
local AutoTab = Window:Tab({
    Title = "Auto",
    Icon = "bot"
})

local autoClaimCoin = false

AutoTab:Toggle({
    Title = "Auto Claim Coin",
    Description = "Automatically trigger prompts in CoinGivers",
    Default = false,
    Callback = function(state)
        autoClaimCoin = state
    end
})

AutoTab:Button({
    Title = "Get all items",
    Description = "Claim all items from ToolImageFolder (Except Classic Timebomb)",
    Callback = function()
        pcall(function()
            local toolFolder = game:GetService("ReplicatedStorage"):FindFirstChild("ToolImageFolder")
            local Event = game:GetService("ReplicatedStorage"):FindFirstChild("RemoteEvents") and game:GetService("ReplicatedStorage").RemoteEvents:FindFirstChild("mapManagerRemote")

            if toolFolder and Event then  
                for _, item in ipairs(toolFolder:GetChildren()) do  
                    if item:IsA("StringValue") and item.Name ~= "Classic Timebomb" then  
                        Event:FireServer("claimTool", item.Name)  
                        task.wait(0.05)  
                    end  
                end  
            end  
        end)  
    end
})

AutoTab:Button({
    Title = "Get Mod",
    Description = "Fire Event to buy Admin Mod (Price: 0)",
    Callback = function()
        pcall(function()
            local Event = game:GetService("ReplicatedStorage"):FindFirstChild("RemoteEvents") and game:GetService("ReplicatedStorage").RemoteEvents:FindFirstChild("mapManagerRemote")
            if Event then
                Event:FireServer("buyAdmin", "Mod", 0)
            end
        end)
    end
})

-- ============================================================
-- [TAB 2: USE COMMAND]
-- ============================================================
local CommandTab = Window:Tab({
    Title = "Use command",
    Icon = "shield-alert"
})

local commandPrefix = "/"
local textCommand = ""
local textName = ""
local textValue = ""
local autoStartCommand = false
local autoStartRunning = false

local function runCommandOnce()
    pcall(function()
        local cmdStr = commandPrefix .. textCommand
        if textName ~= "" then cmdStr = cmdStr .. " " .. textName end
        if textValue ~= "" then cmdStr = cmdStr .. " " .. textValue end

        local Event = game:GetService("ReplicatedStorage"):FindFirstChild("HDAdminHDClient")
        if Event and Event:FindFirstChild("Signals") and Event.Signals:FindFirstChild("RequestCommand") then  
            Event.Signals.RequestCommand:InvokeServer(cmdStr)  
        end
    end)
end

CommandTab:Input({
    Title = "Prefix",
    Value = "/",
    Callback = function(val) commandPrefix = val end
})

CommandTab:Input({
    Title = "Command",
    Value = "",
    Callback = function(val) textCommand = val end
})

CommandTab:Input({
    Title = "Target Name",
    Value = "",
    Callback = function(val) textName = val end
})

CommandTab:Input({
    Title = "Value",
    Value = "",
    Callback = function(val) textValue = val end
})

CommandTab:Button({
    Title = "Start",
    Description = "Execute command once",
    Callback = function()
        runCommandOnce()
    end
})

CommandTab:Toggle({
    Title = "Auto Start",
    Description = "Automatically execute command every 2.5s",
    Default = false,
    Callback = function(state)
        autoStartCommand = state
        
        if state and not autoStartRunning then
            autoStartRunning = true
            task.spawn(function()
                while autoStartCommand do
                    runCommandOnce()
                    task.wait(2.5)
                end
                autoStartRunning = false
            end)
        end
    end
})

