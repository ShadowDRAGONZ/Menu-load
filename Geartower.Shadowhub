})

-- ============================================================
-- [TAB 4: PLAYER]
-- ============================================================
local PlayerTab = Window:Tab({
    Title = "Player",
    Icon = "user"
})

local walkSpeedValue = 16
local autoSpeed = false

PlayerTab:Input({
    Title = "Walk Speed",
    Value = "16",
    Callback = function(val)
        walkSpeedValue = tonumber(val) or 16
    end
})

PlayerTab:Toggle({
    Title = "Auto set speed",
    Description = "Lock your walk speed",
    Default = false,
    Callback = function(state)
        autoSpeed = state
    end
})

local jumpPowerValue = 50
local autoJumpPower = false

PlayerTab:Input({
    Title = "Jump Power",
    Value = "50",
    Callback = function(val)
        jumpPowerValue = tonumber(val) or 50
    end
})

PlayerTab:Toggle({
    Title = "Auto set jump power",
    Description = "Lock your jump power",
    Default = false,
    Callback = function(state)
        autoJumpPower = state
    end
})

local infiniteJump = false

PlayerTab:Toggle({
    Title = "Infinite Jump",
    Description = "Jump continuously in the air",
    Default = false,
    Callback = function(state)
        infiniteJump = state
    end
})

game:GetService("UserInputService").JumpRequest:Connect(function()
    if infiniteJump then
        pcall(function()
            local player = game.Players.LocalPlayer
            if player.Character then
                local humanoid = player.Character:FindFirstChildOfClass("Humanoid")
                if humanoid then
                    humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
                end
            end
        end)
    end
end)

-- ============================================================
-- BACKGROUND LOOPS
-- ============================================================
task.spawn(function()
    while task.wait(0.1) do
        -- (Logic giữ nguyên không thay đổi)
        if autoSpeed or autoJumpPower then  
            pcall(function()  
                local player = game.Players.LocalPlayer  
                if player and player.Character then  
                    local humanoid = player.Character:FindFirstChildOfClass("Humanoid")  
                    if humanoid then  
                        if autoSpeed then humanoid.WalkSpeed = walkSpeedValue end  
                        if autoJumpPower then humanoid.UseJumpPower = true; humanoid.JumpPower = jumpPowerValue end  
                    end  
                end  
            end)  
        end  
        if autoClaimCoin then  
            pcall(function()  
                local givers = workspace:FindFirstChild("Givers")  
                if givers and givers:FindFirstChild("CoinGivers") then  
                    for _, model in ipairs(givers.CoinGivers:GetChildren()) do  
                        if model:IsA("Model") and model:FindFirstChild("ClaimCoin") then  
                            for _, item in ipairs(model.ClaimCoin:GetDescendants()) do  
                                if item:IsA("ProximityPrompt") then fireproximityprompt(item) end  
                            end  
                        end  
                    end  
                end  
            end)  
        end  
        if autoBomb then  
            pcall(function()  
                local Event = game:GetService("ReplicatedStorage"):FindFirstChild("RemoteEvents") and game:GetService("ReplicatedStorage").RemoteEvents:FindFirstChild("mapManagerRemote")
                local LocalPlayer = game.Players.LocalPlayer  
                if Event and LocalPlayer and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then  
                    local backpack = LocalPlayer:FindFirstChild("Backpack")  
                    local hasMyBomb = (backpack and backpack:FindFirstChild("Classic Timebomb")) or LocalPlayer.Character:FindFirstChild("Classic Timebomb")
                    if not hasMyBomb then Event:FireServer("claimTool", "Classic Timebomb") end  
                    if backpack then local b = backpack:FindFirstChild("Classic Timebomb") if b then b.Parent = LocalPlayer.Character end end  
                    for _, p in ipairs(game.Players:GetPlayers()) do  
                        if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then  
                            local h = p.Character:FindFirstChildOfClass("Humanoid")  
                            if h and h.Health > 0 then  
                                local hasTargetBomb = (p:FindFirstChild("Backpack") and p.Backpack:FindFirstChild("Classic Timebomb")) or p.Character:FindFirstChild("Classic Timebomb")  
                                if not hasTargetBomb then LocalPlayer.Character.HumanoidRootPart.CFrame = p.Character.HumanoidRootPart.CFrame * CFrame.new(0, 0, 2); break end  
                            end  
                        end  
                    end  
                end  
            end)  
        end  
        if autoButtonTroll then  
            pcall(function()  
                local trollButtons = workspace:FindFirstChild("TrollButtons")  
                local hrp = game.Players.LocalPlayer.Character and game.Players.LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
                if trollButtons and hrp then  
                    for _, m in ipairs(trollButtons:GetChildren()) do  
                        if m:IsA("Model") and (m.Name == "Button" or m.Name == "button") then  
                            task.spawn(function()  
                                for _, p in ipairs(m:GetChildren()) do  
                                    if p:IsA("BasePart") and (p:FindFirstChildWhichIsA("TouchTransmitter") or p:FindFirstChild("TouchInterest")) then  
                                        firetouchinterest(hrp, p, 0); firetouchinterest(hrp, p, 1); break  
                                    end  
                                end  
                            end)  
                        end  
                    end  
                end  
            end)  
        end  
        if autoTouchDisappearParts then  
            pcall(function()  
                local gearTower = workspace:FindFirstChild("Gear Troll Tower 2")  
                local hrp = game.Players.LocalPlayer.Character and game.Players.LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
                if gearTower and gearTower:FindFirstChild("DisappearParts") and hrp then  
                    for _, p in ipairs(gearTower.DisappearParts:GetChildren()) do  
                        task.spawn(function()  
                            if p:IsA("BasePart") and (p:FindFirstChildWhichIsA("TouchTransmitter") or p:FindFirstChild("TouchInterest")) then  
                                firetouchinterest(hrp, p, 0); firetouchinterest(hrp, p, 1)  
                            end  
                        end)  
                    end  
                end  
            end)  
        end  
    end
end)
