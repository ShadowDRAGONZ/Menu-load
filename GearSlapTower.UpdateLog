dim.Visible = true

local main = make("Frame", { Name = "Main", AnchorPoint = Vector2.new(0.5, 0.5), Position = UDim2.fromScale(0.5, 0.55), Size = UDim2.new(0, 560, 0, 390), BackgroundColor3 = CONFIG.BackgroundColor, BackgroundTransparency = 0.06, BorderSizePixel = 0, Parent = gui, }) corner(main, 20) stroke(main, 1.5, 0.35, CONFIG.AccentColor) addGlow(main)

