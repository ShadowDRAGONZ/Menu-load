local function autoResizeScroll(scroll, layout)
	local function update()
		scroll.CanvasSize = UDim2.new(0, 0, 0, layout.AbsoluteContentSize.Y + 10)
	end
	layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(update)
	update()
end

autoResizeScroll(listHolder, listLayout)
autoResizeScroll(detailScroll, detailLayout)

local starLayer = make("Frame", {
	BackgroundTransparency = 1,
	Size = UDim2.fromScale(1, 1),
	Parent = gui,
})

local stars = {}
for i = 1, 24 do
	local s = make("Frame", {
		BackgroundColor3 = Color3.new(1, 1, 1),
		BackgroundTransparency = 0.2,
		BorderSizePixel = 0,
		Size = UDim2.new(0, math.random(1, 3), 0, math.random(1, 3)),
		Position = UDim2.new(math.random(), math.random(-20, 20), math.random(), math.random(-20, 20)),
		Parent = starLayer,
	})
	corner(s, 999)
	stars[#stars + 1] = {
		obj = s,
		base = s.Position,
		speed = math.random(20, 60) / 100,
		phase = math.random() * math.pi * 2,
	}
end

RunService.RenderStepped:Connect(function(dt)
	for _, st in ipairs(stars) do
		st.phase += dt * st.speed
		st.obj.Position = UDim2.new(st.base.X.Scale, st.base.X.Offset, st.base.Y.Scale + math.sin(st.phase) * 0.003, st.base.Y.Offset)
		st.obj.BackgroundTransparency = 0.2 + (math.sin(st.phase * 1.7) + 1) * 0.25
	end
end)

local dragging = false
local dragStart
local startPos

local function updateDrag(input)
	local delta = input.Position - dragStart
	main.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
end

header.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
		dragging = true
		dragStart = input.Position
		startPos = main.Position
		input.Changed:Connect(function()
			if input.UserInputState == Enum.UserInputState.End then
				dragging = false
			end
		end)
	end
end)

header.InputChanged:Connect(function(input)
	if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
		updateDrag(input)
	end
end)

local function clearDetails()
	for _, child in ipairs(detailScroll:GetChildren()) do
		if child:IsA("GuiObject") and child.Name ~= "UIListLayout" and child.Name ~= "UIPadding" then
			child:Destroy()
		end
	end
end

local function addDetailLine(text, isTitle)
	return make("TextLabel", {
		BackgroundTransparency = 1,
		Size = UDim2.new(1, 0, 0, isTitle and 24 or 20),
		AutomaticSize = Enum.AutomaticSize.Y,
		Font = isTitle and Enum.Font.GothamBold or Enum.Font.GothamMedium,
		Text = text,
		TextWrapped = true,
		TextXAlignment = Enum.TextXAlignment.Left,
		TextYAlignment = Enum.TextYAlignment.Top,
		TextSize = isTitle and 15 or 13,
		TextColor3 = isTitle and CONFIG.TextColor or CONFIG.MutedText,
		Parent = detailScroll,
	})
end

local function showUpdate(entry)
	clearDetails()

	detailTitle.Text = safeToString(entry.title or entry.version or "Update")
	detailMeta.Text = string.format("Version %s • %s", safeToString(entry.version or "Unknown"), formatDate(entry.date))

	addDetailLine(safeToString(entry.description or entry.summary or "No description"), false)
	addDetailLine("", false)
	addDetailLine("Highlights", true)

	local bullets = entry.features or entry.bullets or entry.points
	if type(bullets) == "table" and #bullets > 0 then
		for _, line in ipairs(bullets) do
			addDetailLine("• " .. safeToString(line), false)
		end
	else
		addDetailLine("• Smooth galaxy UI", false)
		addDetailLine("• GitHub raw sync", false)
		addDetailLine("• Clean compact layout", false)
		addDetailLine("• Delete button only", false)
	end

	addDetailLine("", false)
	addDetailLine("Status", true)
	addDetailLine(safeToString(entry.status or "Stable • Ready to use"), false)

	if entry.notes or entry.note then
		addDetailLine("", false)
		addDetailLine("Notes", true)
		addDetailLine(safeToString(entry.notes or entry.note), false)
	end
end

local function createEntryCard(entry, index)
	local card = make("TextButton", {
		Name = "EntryCard",
		AutoButtonColor = false,
		BackgroundColor3 = CONFIG.CardColor,
		BackgroundTransparency = 0.08,
		BorderSizePixel = 0,
		Size = UDim2.new(1, -4, 0, 64),
		Text = "",
		Parent = listHolder,
	})
	corner(card, 12)
	stroke(card, 1, 0.72, CONFIG.Accent1)

	local badge = make("Frame", {
		BackgroundColor3 = (index % 2 == 0) and CONFIG.Accent2 or CONFIG.Accent3,
		Size = UDim2.new(0, 7, 1, -16),
		Position = UDim2.new(0, 8, 0, 8),
		BorderSizePixel = 0,
		Parent = card,
	})
	corner(badge, 999)

	make("TextLabel", {
		BackgroundTransparency = 1,
		Position = UDim2.new(0, 22, 0, 6),
		Size = UDim2.new(1, -30, 0, 22),
		Font = Enum.Font.GothamBold,
		Text = safeToString(entry.title or entry.version or ("Update " .. index)),
		TextSize = 14,
		TextXAlignment = Enum.TextXAlignment.Left,
		TextColor3 = CONFIG.TextColor,
		Parent = card,
	})

	make("TextLabel", {
		BackgroundTransparency = 1,
		Position = UDim2.new(0, 22, 0, 26),
		Size = UDim2.new(1, -30, 0, 16),
		Font = Enum.Font.GothamMedium,
		Text = safeToString(entry.version or "Info") .. " • " .. formatDate(entry.date),
		TextSize = 11,
		TextXAlignment = Enum.TextXAlignment.Left,
		TextColor3 = CONFIG.MutedText,
		Parent = card,
	})

	make("TextLabel", {
		BackgroundTransparency = 1,
		Position = UDim2.new(0, 22, 0, 42),
		Size = UDim2.new(1, -34, 0, 14),
		Font = Enum.Font.Gotham,
		Text = safeToString(entry.description or entry.summary or "Click to view details"),
		TextSize = 11,
		TextXAlignment = Enum.TextXAlignment.Left,
		TextColor3 = Color3.fromRGB(205, 210, 225),
		TextTransparency = 0.1,
		TextTruncate = Enum.TextTruncate.AtEnd,
		Parent = card,
	})

	card.MouseEnter:Connect(function()
		tween(card, TweenInfo.new(0.15), {BackgroundTransparency = 0})
	end)
	card.MouseLeave:Connect(function()
		tween(card, TweenInfo.new(0.15), {BackgroundTransparency = 0.08})
	end)
	card.MouseButton1Click:Connect(function()
		createRipple(card)
		showUpdate(entry)
	end)

	return card
end

local function setStatus(msg, good)
	statusLabel.Text = msg
	statusLabel.TextColor3 = good and CONFIG.Accent2 or CONFIG.Accent3
end

local function fillUpdates(data)
	for _, child in ipairs(listHolder:GetChildren()) do
		if child:IsA("TextButton") and child.Name == "EntryCard" then
			child:Destroy()
		end
	end

	local entries = data.entries or {}
	if #entries == 0 then
		setStatus("No update entries found", false)
		detailTitle.Text = "No data"
		detailMeta.Text = "GitHub returned empty content"
		clearDetails()
		addDetailLine("No update items were found in the GitHub file.", false)
		addDetailLine("Check your JSON format and the raw link.", false)
		return
	end

	setStatus("Synced successfully • " .. tostring(#entries) .. " entries", true)
	for i, entry in ipairs(entries) do
		createEntryCard(entry, i)
	end
	showUpdate(entries[1])
end

local function refreshData()
	setStatus("Refreshing from GitHub...", true)
	local data, err = loadUpdates()
	if not data then
		setStatus(err or "Refresh failed", false)
		return
	end
	if data.title and data.title ~= "" then
		title.Text = data.title
	end
	if data.subtitle and data.subtitle ~= "" then
		subtitle.Text = data.subtitle
	end
	fillUpdates(data)
end

deleteBtn.MouseButton1Click:Connect(function()
	createRipple(deleteBtn)
	if blur then blur:Destroy() end
	if gui then gui:Destroy() end
end)

refreshBtn.MouseButton1Click:Connect(function()
	createRipple(refreshBtn)
	refreshData()
end)

task.spawn(function()
	while task.wait(CONFIG.AutoRefreshSeconds) do
		if gui.Parent then
			refreshData()
		end
	end
end)

dim.BackgroundTransparency = 0.35
main.BackgroundTransparency = 0.06

local pulse = 0
task.spawn(function()
	while gui.Parent do
		pulse += 0.02
		local alpha = 0.6 + math.sin(pulse) * 0.12
		for _, obj in ipairs({header, leftPanel, rightPanel, main}) do
			local st = obj:FindFirstChildOfClass("UIStroke")
			if st then
				st.Transparency = math.clamp(alpha, 0.3, 0.8)
			end
		end
		task.wait(0.08)
	end
end)

refreshData()
