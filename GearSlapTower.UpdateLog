--// Galaxy Update Log Menu --// LocalScript (StarterPlayerScripts / StarterGui) --// Reads update log from a GitHub raw .txt or .json file

local Players = game:GetService("Players") local TweenService = game:GetService("TweenService") local RunService = game:GetService("RunService") local HttpService = game:GetService("HttpService") local UserInputService = game:GetService("UserInputService") local Lighting = game:GetService("Lighting")

local LocalPlayer = Players.LocalPlayer local PlayerGui = LocalPlayer:WaitForChild("PlayerGui")

--==================================================== -- CONFIG --==================================================== local CONFIG = { Title = "GALAXY UPDATE LOG", Subtitle = "Premium Cosmic Interface", GithubRawUrl = "https://raw.githubusercontent.com/ShadowDRAGONZ/Menu-load/refs/heads/main/update.txt", AutoRefreshSeconds = 30, AccentColor = Color3.fromRGB(163, 111, 255), AccentColor2 = Color3.fromRGB(72, 214, 255), AccentColor3 = Color3.fromRGB(255, 121, 198), BackgroundColor = Color3.fromRGB(10, 12, 20), PanelColor = Color3.fromRGB(18, 22, 36), TextColor = Color3.fromRGB(245, 247, 255), MutedText = Color3.fromRGB(170, 176, 196), }

--==================================================== -- CLEANUP OLD GUI IF RELOADED --==================================================== local old = PlayerGui:FindFirstChild("GalaxyUpdateLogGui") if old then old:Destroy() end

--==================================================== -- HELPERS --==================================================== local function make(className, props) local inst = Instance.new(className) for k, v in pairs(props or {}) do inst[k] = v end return inst end

local function tween(obj, info, goal) local tw = TweenService:Create(obj, info, goal) tw:Play() return tw end

local function corner(parent, radius) local c = Instance.new("UICorner") c.CornerRadius = UDim.new(0, radius or 12) c.Parent = parent return c end

local function stroke(parent, thickness, transparency, color) local s = Instance.new("UIStroke") s.Thickness = thickness or 1 s.Transparency = transparency or 0.35 s.Color = color or CONFIG.AccentColor s.ApplyStrokeMode = Enum.ApplyStrokeMode.Border s.Parent = parent return s end

local function gradient(parent, c1, c2, rotation) local g = Instance.new("UIGradient") g.Color = ColorSequence.new({ ColorSequenceKeypoint.new(0, c1 or CONFIG.AccentColor), ColorSequenceKeypoint.new(1, c2 or CONFIG.AccentColor2), }) g.Rotation = rotation or 0 g.Parent = parent return g end

local function addGlow(parent) local glow = Instance.new("ImageLabel") glow.Name = "Glow" glow.BackgroundTransparency = 1 glow.Image = "rbxassetid://1316045217" glow.ImageTransparency = 0.55 glow.ScaleType = Enum.ScaleType.Slice glow.SliceCenter = Rect.new(10, 10, 118, 118) glow.Size = UDim2.new(1, 160, 1, 160) glow.Position = UDim2.new(0.5, 0, 0.5, 0) glow.AnchorPoint = Vector2.new(0.5, 0.5) glow.ZIndex = (parent.ZIndex or 1) - 1 glow.Parent = parent return glow end

local function createRipple(parent) local ripple = Instance.new("Frame") ripple = ripple ripple.Name = "Ripple" ripple.BackgroundTransparency = 1 ripple.BorderSizePixel = 0 ripple.Size = UDim2.fromScale(0, 0) ripple.AnchorPoint = Vector2.new(0.5, 0.5) ripple.Position = UDim2.fromScale(0.5, 0.5) ripple.ZIndex = 50 ripple.Parent = parent

corner(ripple, 999)

local s = Instance.new("UIStroke")
s.Color = CONFIG.AccentColor2
s.Thickness = 2
s.Transparency = 0.1
s.Parent = ripple

task.spawn(function()
	tween(ripple, TweenInfo.new(0.75, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
		Size = UDim2.fromScale(2.2, 2.2),
		BackgroundTransparency = 1,
	})
	task.wait(0.8)
	if ripple then ripple:Destroy() end
end)

end

local function safeToString(v) if v == nil then return "" end return tostring(v) end

local function formatDate(ts) if type(ts) == "number" then return os.date("%d %b %Y", ts) end return tostring(ts or "Unknown") end

local function isArray(t) if type(t) ~= "table" then return false end for k, _ in pairs(t) do if type(k) ~= "number" then return false end end return true end

local function parsePlainText(raw) local entries = {} local lines = {}

for line in tostring(raw):gmatch("[^

]+") do line = line:gsub("^%s+", ""):gsub("%s+$", "") if line ~= "" then table.insert(lines, line) end end

if #lines == 0 then
	return entries
end

for _, line in ipairs(lines) do
	-- Support: [1.0.0] - Title | Description
	local version, title, desc = line:match("^%[(.-)%]%s*%-%s*(.-)%s*%|%s*(.-)%s*$")
	if version then
		table.insert(entries, {
			version = version,
			title = title,
			description = desc,
			date = os.time(),
			status = "Stable",
		})
	else
		-- Support simple bullet / plain lines
		local bullet = line:gsub("^%-%s*", ""):gsub("^•%s*", "")
		table.insert(entries, {
			version = "Info",
			title = bullet,
			description = "",
			date = os.time(),
			status = "Stable",
		})
	end
end

return entries

end

local function parseUpdateData(raw) local ok, decoded = pcall(function() return HttpService:JSONDecode(raw) end)

if ok and type(decoded) == "table" then
	if decoded.entries and type(decoded.entries) == "table" then
		return decoded.entries, decoded.title, decoded.subtitle
	end
	if isArray(decoded) then
		return decoded, nil, nil
	end
end

return parsePlainText(raw), nil, nil

end

local function fetchUpdateData() local ok, result = pcall(function() return HttpService:GetAsync(CONFIG.GithubRawUrl, true) end) if not ok then return nil, "Không tải được dữ liệu từ GitHub" end

local entries, title, subtitle = parseUpdateData(result)
return {
	entries = entries or {},
	title = title,
	subtitle = subtitle,
}, nil

end

