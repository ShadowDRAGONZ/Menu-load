--// UPDATE LOG MENU
--// English-only UI
--// Left side = update list from GitHub
--// Right side = selected update details from GitHub
--// Put your JSON file on GitHub raw link

local Players = game:GetService("Players")
local TweenService = game:GetService("TweenService")
local RunService = game:GetService("RunService")
local Lighting = game:GetService("Lighting")

local LocalPlayer = Players.LocalPlayer
local PlayerGui = LocalPlayer:WaitForChild("PlayerGui")

local CONFIG = {
	Title = "UPDATE LOG",
	Subtitle = "Gear Slap Tower Update Log",
	GithubRawUrl = "https://raw.githubusercontent.com/ShadowDRAGONZ/Menu-load/refs/heads/main/update.txt",
	AutoRefreshSeconds = 30,

	BackgroundColor = Color3.fromRGB(10, 12, 20),
	PanelColor = Color3.fromRGB(18, 22, 36),
	CardColor = Color3.fromRGB(24, 28, 45),

	TextColor = Color3.fromRGB(245, 247, 255),
	MutedText = Color3.fromRGB(170, 176, 196),

	Accent1 = Color3.fromRGB(163, 111, 255),
	Accent2 = Color3.fromRGB(72, 214, 255),
	Accent3 = Color3.fromRGB(255, 121, 198),
}

local function make(className, props)
	local inst = Instance.new(className)
	for k, v in pairs(props or {}) do
		inst[k] = v
	end
	return inst
end

local function corner(parent, radius)
	local c = Instance.new("UICorner")
	c.CornerRadius = UDim.new(0, radius or 12)
	c.Parent = parent
	return c
end

local function stroke(parent, thickness, transparency, color)
	local s = Instance.new("UIStroke")
	s.Thickness = thickness or 1
	s.Transparency = transparency or 0.35
	s.Color = color or CONFIG.Accent1
	s.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
	s.Parent = parent
	return s
end

local function gradient(parent, c1, c2, rotation)
	local g = Instance.new("UIGradient")
	g.Color = ColorSequence.new({
		ColorSequenceKeypoint.new(0, c1 or CONFIG.Accent1),
		ColorSequenceKeypoint.new(1, c2 or CONFIG.Accent2),
	})
	g.Rotation = rotation or 0
	g.Parent = parent
	return g
end

local function tween(obj, info, goal)
	local tw = TweenService:Create(obj, info, goal)
	tw:Play()
	return tw
end

local function addGlow(parent)
	local glow = Instance.new("ImageLabel")
	glow.BackgroundTransparency = 1
	glow.Image = "rbxassetid://1316045217"
	glow.ImageTransparency = 0.55
	glow.ScaleType = Enum.ScaleType.Slice
	glow.SliceCenter = Rect.new(10, 10, 118, 118)
	glow.Size = UDim2.new(1, 160, 1, 160)
	glow.Position = UDim2.new(0.5, 0, 0.5, 0)
	glow.AnchorPoint = Vector2.new(0.5, 0.5)
	glow.ZIndex = (parent.ZIndex or 1) - 1
	glow.Parent = parent
	return glow
end

local function createRipple(parent)
	local ripple = Instance.new("Frame")
	ripple.Name = "Ripple"
	ripple.BackgroundTransparency = 1
	ripple.BorderSizePixel = 0
	ripple.Size = UDim2.fromScale(0, 0)
	ripple.AnchorPoint = Vector2.new(0.5, 0.5)
	ripple.Position = UDim2.fromScale(0.5, 0.5)
	ripple.ZIndex = 50
	ripple.Parent = parent
	corner(ripple, 999)

	local s = Instance.new("UIStroke")
	s.Color = CONFIG.Accent2
	s.Thickness = 2
	s.Transparency = 0.1
	s.Parent = ripple

	task.spawn(function()
		tween(ripple, TweenInfo.new(0.75, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
			Size = UDim2.fromScale(2.2, 2.2),
			BackgroundTransparency = 1,
		})
		task.wait(0.8)
		if ripple then ripple:Destroy() end
	end)
end

local function safeToString(v)
	if v == nil then return "" end
	return tostring(v)
end

local function formatDate(v)
	if type(v) == "number" then
		return os.date("%d %b %Y", v)
	end
	return tostring(v or "Unknown")
end

local function isArray(t)
	if type(t) ~= "table" then return false end
	for k, _ in pairs(t) do
		if type(k) ~= "number" then
			return false
		end
	end
	return true
end

local function jsonEncode(tbl)
	return game:GetService("HttpService"):JSONEncode(tbl)
end

local function tryDecode(raw)
	local ok, decoded = pcall(function()
		return game:GetService("HttpService"):JSONDecode(raw)
	end)
	if ok then
		return decoded
	end
	return nil
end

local function fetchRaw(url)
	local ok, result = pcall(function()
		return game:HttpGet(url, true)
	end)
	if ok and type(result) == "string" and result ~= "" then
		return result
	end
	return nil
end

--====================================================
-- DATA
--====================================================
local function loadUpdates()
	local raw = fetchRaw(CONFIG.GithubRawUrl)
	if not raw then
		return nil, "Failed to fetch GitHub raw file."
	end

	local decoded = tryDecode(raw)
	if type(decoded) ~= "table" then
		return nil, "GitHub file must be valid JSON."
	end

	-- Accepted format:
	-- { title = "...", subtitle = "...", entries = { ... } }
	-- or directly an array of entries
	local data = {
		title = decoded.title or CONFIG.Title,
		subtitle = decoded.subtitle or CONFIG.Subtitle,
		entries = {},
	}

	if decoded.entries and type(decoded.entries) == "table" then
		data.entries = decoded.entries
	elseif isArray(decoded) then
		data.entries = decoded
	end

	return data, nil
end

