--              ⚙️ SERVICES
-- ══════════════════════════════════════════

local Players = game:GetService("Players")
local TweenService = game:GetService("TweenService")
local HttpService = game:GetService("HttpService")

local LocalPlayer = Players.LocalPlayer
local PlayerGui = LocalPlayer:WaitForChild("PlayerGui")

local placeId = game.PlaceId
local gameData = games[placeId]

if not gameData then
    LocalPlayer:Kick("❌ Game này không được hỗ trợ!")
    return
end

-- ══════════════════════════════════════════
--              🧩 HELPERS
-- ══════════════════════════════════════════

local function new(className, props)
    local obj = Instance.new(className)
    for k, v in pairs(props or {}) do
        obj[k] = v
    end
    return obj
end

local function corner(parent, radius)
    local c = Instance.new("UICorner")
    c.CornerRadius = radius or UDim.new(0, 12)
    c.Parent = parent
    return c
end

local function stroke(parent, color, transparency, thickness)
    local s = Instance.new("UIStroke")
    s.Color = color or Color3.fromRGB(255, 255, 255)
    s.Transparency = transparency or 0.8
    s.Thickness = thickness or 1
    s.Parent = parent
    return s
end

local function gradient(parent, c1, c2, rotation)
    local g = Instance.new("UIGradient")
    g.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0, c1),
        ColorSequenceKeypoint.new(1, c2),
    })
    g.Rotation = rotation or 0
    g.Parent = parent
    return g
end

local function safeHttpGet(url)
    local ok, res = pcall(function()
        return game:HttpGet(url)
    end)
    if not ok then
        return nil, res
    end
    return res
end

local function saveKey(key)
    if type(writefile) == "function" then
        pcall(function()
            writefile(SAVE_FILE, key)
        end)
    end
end

local function loadSavedKey()
    if type(readfile) == "function" then
        local ok, data = pcall(function()
            return readfile(SAVE_FILE)
        end)
        if ok and type(data) == "string" and #data > 0 then
            return data
        end
    end
    return nil
end

local function formatMinutesLeft(seconds)
    if not seconds then
        return "Lifetime"
    end

    if seconds <= 0 then
        return "Hết hạn"
    end

    local mins = math.floor(seconds / 60)
    local hours = math.floor(mins / 60)
    local days = math.floor(hours / 24)

    if days > 0 then
        return string.format("%d ngày %d giờ", days, hours % 24)
    elseif hours > 0 then
        return string.format("%d giờ %d phút", hours, mins % 60)
    else
        return string.format("%d phút", mins)
    end
end

local function fadeOutGui(gui)
    for _, obj in ipairs(gui:GetDescendants()) do
        if obj:IsA("Frame") or obj:IsA("TextLabel") or obj:IsA("TextButton") or obj:IsA("TextBox") then
            pcall(function()
                TweenService:Create(obj, TweenInfo.new(0.35, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
                    BackgroundTransparency = 1,
                    TextTransparency = obj.TextTransparency and 1 or nil
                }):Play()
            end)
        end
        if obj:IsA("UIStroke") then
            pcall(function()
                TweenService:Create(obj, TweenInfo.new(0.35), { Transparency = 1 }):Play()
            end)
        end
    end
end

local function shake(frame)
    local original = frame.Position
    local offsets = {
        UDim2.new(original.X.Scale, original.X.Offset - 8, original.Y.Scale, original.Y.Offset),
        UDim2.new(original.X.Scale, original.X.Offset + 8, original.Y.Scale, original.Y.Offset),
        UDim2.new(original.X.Scale, original.X.Offset - 6, original.Y.Scale, original.Y.Offset),
        UDim2.new(original.X.Scale, original.X.Offset + 6, original.Y.Scale, original.Y.Offset),
        original
    }

    task.spawn(function()
        for _, pos in ipairs(offsets) do
            TweenService:Create(frame, TweenInfo.new(0.05, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
                Position = pos
            }):Play()
            task.wait(0.05)
        end
    end)
end

local function requestKeyCheck(key)
    local url = KEY_API_URL .. HttpService:UrlEncode(key)
    local raw = safeHttpGet(url)
    if not raw then
        return false, "Không kết nối được tới máy chủ key."
    end

    local ok, data = pcall(function()
        return HttpService:JSONDecode(raw)
    end)

    if not ok or type(data) ~= "table" then
        return false, "Phản hồi từ server không hợp lệ."
    end

    if data.valid == true then
        return true, data
    end

    return false, data.reason or "Key không hợp lệ."
end

local function verifyKey(key)
    if not key or key == "" then
        return false, "Vui lòng nhập key."
    end

    key = key:gsub("^%s+", ""):gsub("%s+$", "")
    return requestKeyCheck(key)
end

local function loadGameScript()
    local ok, err = pcall(function()
        local code = game:HttpGet(gameData.script)
        local fn = loadstring(code)
        if not fn then
            error("Không thể compile script.")
        end
        fn()
    end)

    if not ok then
        warn("[ShadowHub] Load script failed:", err)
    end
end

