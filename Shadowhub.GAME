-- ══════════════════════════════════════════
--              🔁 LOADING LOGIC
-- ══════════════════════════════════════════

local function setLoadProgress(p)
    TweenService:Create(loadBar, TweenInfo.new(0.4, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
        Size = UDim2.new(p / 100, 0, 1, 0)
    }):Play()
end

local function showLoading()
    loadingCard.Visible = true
    loadingCard.BackgroundTransparency = 0
    for _, obj in ipairs(loadingCard:GetDescendants()) do
        if obj:IsA("TextLabel") or obj:IsA("TextButton") or obj:IsA("TextBox") then
            obj.TextTransparency = 0
        end
        if obj:IsA("Frame") then
            obj.BackgroundTransparency = obj == loadBar and 0 or 0
        end
    end
end

local function startLoaderSequence()
    showLoading()

    local steps = {
        { text = "Checking modules...", pct = 20 },
        { text = "Loading assets...", pct = 50 },
        { text = "Preparing scripts...", pct = 80 },
        { text = "Launching...", pct = 100 },
    }

    task.spawn(function()
        local last = 0
        for _, step in ipairs(steps) do
            loadStatus.Text = step.text
            loadStep.Text = step.text
            setLoadProgress(step.pct)

            for i = last, step.pct do
                loadPercent.Text = i .. "%"
                task.wait(0.01)
            end

            last = step.pct
            task.wait(0.25)
        end
    end)

    task.delay(3, function()
        loadStatus.Text = "Success"
        loadInfo.Text = "Script loaded successfully."
        loadStep.Text = "Done"
        loadPercent.Text = "100%"

        task.wait(0.4)
        fadeOutGui(bg)
        task.wait(0.5)
        if screenGui then
            screenGui:Destroy()
        end

        loadGameScript()
    end)
end

local function acceptKey(key, data)
    saveKey(key)
    keyStatus.Text = "✅ Key valid"
    if type(data) == "table" and data.expires_at then
        keyHint.Text = "Expire: " .. tostring(data.expires_at)
    else
        keyHint.Text = "Access granted."
    end

    task.wait(0.4)
    keyCard.Visible = false
    startLoaderSequence()
end

local function rejectKey(reason)
    keyStatus.Text = "❌ " .. tostring(reason or "Invalid key")
    keyHint.Text = "Please try again."
    shake(keyCard)
end

local function handleVerify()
    local key = keyBox.Text
    keyStatus.Text = "Verifying..."
    keyHint.Text = "Please wait..."
    keyBar.Size = UDim2.new(0, 0, 1, 0)
    TweenService:Create(keyBar, TweenInfo.new(0.35, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
        Size = UDim2.new(0.35, 0, 1, 0)
    }):Play()

    local ok, result = verifyKey(key)
    if ok then
        keyBar.Size = UDim2.new(1, 0, 1, 0)
        acceptKey(key, result)
    else
        keyBar.Size = UDim2.new(0, 0, 1, 0)
        rejectKey(result)
    end
end

submit.MouseButton1Click:Connect(handleVerify)

keyBox.FocusLost:Connect(function(enterPressed)
    if enterPressed then
        handleVerify()
    end
end)

getKey.MouseButton1Click:Connect(function()
    if type(setclipboard) == "function" then
        pcall(function()
            setclipboard(KEY_WEB_URL)
        end)
        keyStatus.Text = "📋 Key website copied"
        keyHint.Text = "Open the link in your browser."
    else
        keyStatus.Text = "🌐 Open key website"
        keyHint.Text = KEY_WEB_URL
    end
end)

-- ══════════════════════════════════════════
--              ✅ AUTO KEY CHECK
-- ══════════════════════════════════════════

task.spawn(function()
    local saved = loadSavedKey()
    if saved and #saved > 0 then
        keyStatus.Text = "Checking saved key..."
        local ok, result = verifyKey(saved)
        if ok then
            keyBox.Text = saved
            acceptKey(saved, result)
            return
        end
    end

    keyStatus.Text = "Waiting for key..."
end)